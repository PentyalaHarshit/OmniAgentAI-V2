USE_OLLAMA=true
# Local host: http://localhost:11434
# Docker Compose service URL: http://ollama:11434
OLLAMA_BASE_URL=http://localhost:11434

QWEN_MODEL=qwen2.5-coder:7b
DEEPSEEK_MODEL=deepseek-coder:6.7b
LLAMA_MODEL=llama3.2:3b
MISTRAL_MODEL=mistral:7b
PHI_MODEL=phi3:mini

CPP_COMPILER=g++
PYTHON_BIN=python
MAX_SELF_CORRECT_ROUNDS=2
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Upload/object storage
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=uploads

# Amazon S3, when STORAGE_PROVIDER=s3
S3_BUCKET=your_bucket
S3_PREFIX=omniagentai/uploads
AWS_REGION=us-east-1

# Azure Blob Storage, when STORAGE_PROVIDER=azure_blob
AZURE_STORAGE_CONNECTION_STRING=your_connection_string
AZURE_STORAGE_CONTAINER=your_container
AZURE_STORAGE_PREFIX=omniagentai/uploads

# Multithreaded LLM tree
LLM_TREE_MAX_WORKERS=5
LLM_TREE_MODEL_TIMEOUT=90

# Inference backend: ollama, vllm, or hybrid
LLM_BACKEND=ollama

# vLLM OpenAI-compatible servers
VLLM_QWEN_URL=http://localhost:8001/v1
VLLM_DEEPSEEK_URL=http://localhost:8002/v1
VLLM_LLAMA_URL=http://localhost:8003/v1
VLLM_MISTRAL_URL=http://localhost:8004/v1
VLLM_PHI_URL=http://localhost:8005/v1

VLLM_QWEN_MODEL=Qwen/Qwen2.5-Coder-7B-Instruct
VLLM_DEEPSEEK_MODEL=deepseek-ai/deepseek-coder-6.7b-instruct
VLLM_LLAMA_MODEL=meta-llama/Llama-3.2-3B-Instruct
VLLM_MISTRAL_MODEL=mistralai/Mistral-7B-Instruct-v0.3
VLLM_PHI_MODEL=microsoft/Phi-3-mini-4k-instruct

VLLM_API_KEY=EMPTY
VLLM_TEMPERATURE=0.2
VLLM_MAX_TOKENS=512

# Optional Codeforces authenticated page access.
# Do not put your Codeforces email or password here.
# If source pages require login, use either CODEFORCES_COOKIE in your local .env
# or keep the cookie in an ignored local file and point CODEFORCES_COOKIE_FILE to it.
CODEFORCES_COOKIE=JSESSIONID=BFA08C45BD0B347A4847181C5199C932
CODEFORCES_COOKIE_FILE=secrets/codeforces_cookie.txt

